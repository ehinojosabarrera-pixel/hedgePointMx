[Unit]
Description=HedgePoint Dashboard (FastAPI/uvicorn)
After=network.target

[Service]
Type=simple
User=hedgepoint
WorkingDirectory=/home/hedgepoint/app
EnvironmentFile=/home/hedgepoint/app/.env
Environment="PATH=/home/hedgepoint/app/venv/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin"
ExecStart=/home/hedgepoint/app/venv/bin/uvicorn agents.reports.dashboard:app --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
